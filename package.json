{
  "name": "sms-to-claude",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "ssh": "ssh -o ConnectTimeout=5 -p 2222 yvz@localhost",
    "attach": "ssh -o ConnectTimeout=5 -p 2222 -tt yvz@localhost 'tmux -S /tmp/claude-sms-tmux attach -t claude-sms'",
    "diagnose": "ssh -o ConnectTimeout=5 -p 2222 yvz@localhost '~/sms-to-claude/scripts/diagnose.sh' || echo '[FAIL] Could not connect to VM — VM may be down or unreachable'",
    "diagnosis:start": "pm2 start src/diagnosis-server.ts --name claude-diagnosis-dashboard --interpreter bun",
    "diagnosis:stop": "pm2 stop claude-diagnosis-dashboard",
    "diagnosis:logs": "pm2 logs claude-diagnosis-dashboard",
    "diagnosis-server": "bun run src/diagnosis-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "android-sms-gateway": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
